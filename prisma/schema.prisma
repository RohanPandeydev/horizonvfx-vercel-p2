// This is your Prisma schema file for Vercel Postgres production
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Enable connection pooling for Vercel
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String?
  lastName      String?
  role          String    @default("user")
  emailVerified Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpires DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tokens        Token[]
  uploadedMedia Media[]   @relation("UploadedBy")
  uploadedProjects VideoProject[] @relation("UploadedProjects")
}

model Token {
  id           String    @id @default(cuid())
  token        String    @unique
  userId       String
  type         String    // 'access' or 'refresh'
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// Page Content Model - Stores JSON content for dynamic pages
model PageContent {
  id          String   @id @default(cuid())
  slug        String   @unique // 'contact', 'about', 'home', etc.
  title       String
  content     String   // JSON string containing all page sections
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // userId of last updater

  @@index([slug])
  @@index([published])
}

// Contact Submissions Model
model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  subject     String?
  message     String
  status      String   @default("new") // 'new', 'read', 'replied', 'archived'
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// Site Settings Model
model SiteSettings {
  id          String   @id @default(cuid())
  key         String   @unique // 'contact_email', 'social_media', etc.
  value       String   // JSON string for complex values
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// Media Model - Stores uploaded file metadata
model Media {
  id           String    @id @default(cuid())
  filename     String              // S3 object key
  originalName String              // Original filename
  mimeType     String              // image/jpeg, video/mp4, etc.
  size         Int                 // File size in bytes
  s3Key        String              // S3 object key (path)
  s3Bucket     String              // S3 bucket name
  s3Region     String              // AWS region
  url          String              // S3 object URL (for reference, not direct access)
  uploadedBy   String              // userId who uploaded
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  uploader     User       @relation("UploadedBy", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([uploadedBy])
  @@index([mimeType])
  @@index([createdAt])
}

// Home Page Configuration Model
model HomePageConfig {
  id                String   @id @default(cuid())
  showExcellence    Boolean  @default(true)
  showLeadership    Boolean  @default(true)
  showTechStack     Boolean  @default(true)
  showStats         Boolean  @default(true)
  showProjects      Boolean  @default(true)
  showShowreel      Boolean  @default(true)
  showClients       Boolean  @default(true)
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Video Project Model - For showcase/media library
model VideoProject {
  id             String    @id @default(cuid())
  title          String
  type           String              // 'project' or 'reel'
  isReel         Boolean   @default(false)
  thumbnailUrl   String              // Public URL for display
  videoUrl       String?             // Public URL for display (optional)
  thumbnailS3Key String              // S3 object key for deletion
  videoS3Key     String?             // S3 object key for deletion (optional)
  category       String
  isFeatured     Boolean   @default(false)
  isPublic       Boolean   @default(true)
  description    String?
  gradient       String    @default("from-blue-500 to-purple-500")
  stats          String?
  technologies   String?   // JSON string array: ["Nuke", "Maya"]
  uploadedBy     String              // userId who uploaded
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  uploader       User      @relation("UploadedProjects", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([category])
  @@index([isFeatured])
  @@index([uploadedBy])
}
